{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "g4mf.node.schema.json",
	"title": "G4MF Scene Node",
	"type": "object",
	"description": "A node in the scene hierarchy, representing an object in the scene. Nodes are transformable, may have children, and may have other data attached to them to define the type of object they represent. Nodes are highly recommended to have a name, and if defined, the name MUST be unique within the G4MF file.",
	"allOf": [{ "$ref": "g4mf_transform.schema.json" }],
	"properties": {
		"bone": {
			"$ref": "mesh/deformation/g4mf.node.bone.schema.json"
		},
		"camera": {
			"$ref": "g4mf.node.camera.schema.json"
		},
		"children": {
			"type": "array",
			"description": "The indices of this node's children.",
			"items": {
				"allOf": [{ "$ref": "g4mf_index.schema.json" }],
				"minimum": 1
			},
			"uniqueItems": true,
			"minItems": 1
		},
		"light": {
			"allOf": [{ "$ref": "g4mf_index.schema.json" }],
			"description": "The index of the light that this node references. This is a reference to a light in the G4MF file's lights array. If not defined, this node is not a light source."
		},
		"meshInstance": {
			"$ref": "mesh/g4mf.node.mesh_instance.schema.json"
		},
		"modelInstance": {
			"$ref": "g4mf.node.model_instance.schema.json"
		},
		"physics": {
			"$ref": "physics/g4mf.node.physics.schema.json"
		},
		"skeleton": {
			"$ref": "mesh/deformation/g4mf.node.skeleton.schema.json"
		},
		"visible": {
			"type": "boolean",
			"description": "Whether the node is visible. If false, the node and its children are not rendered.",
			"default": true
		}
	},
	"not": {
		"anyOf": [
			{ "required": ["bone", "camera"] },
			{ "required": ["bone", "light"] },
			{ "required": ["bone", "meshInstance"] },
			{ "required": ["bone", "modelInstance"] },
			{ "required": ["bone", "physics"] },
			{ "required": ["bone", "skeleton"] },
			{ "required": ["camera", "light"] },
			{ "required": ["camera", "meshInstance"] },
			{ "required": ["camera", "modelInstance"] },
			{ "required": ["camera", "physics"] },
			{ "required": ["camera", "skeleton"] },
			{ "required": ["light", "meshInstance"] },
			{ "required": ["light", "modelInstance"] },
			{ "required": ["light", "physics"] },
			{ "required": ["light", "skeleton"] },
			{ "required": ["meshInstance", "modelInstance"] },
			{ "required": ["meshInstance", "physics"] },
			{ "required": ["meshInstance", "skeleton"] },
			{ "required": ["modelInstance", "physics"] },
			{ "required": ["modelInstance", "skeleton"] },
			{ "required": ["physics", "skeleton"] }
		]
	}
}
